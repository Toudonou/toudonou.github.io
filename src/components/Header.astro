---
import { siteConfig, translations } from "../config";
import { type Language } from "../i18n";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang];
const otherLang: Language = lang === "fr" ? "en" : "fr";

const hasProjects = t.projects && t.projects.length > 0;
const hasExperience = t.experience && t.experience.length > 0;
const hasEducation = t.education && t.education.length > 0;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 hidden md:block transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-8 py-4">
    <ul class="flex items-center gap-8 justify-center">
      <li>
        <a
          href={`/${lang}#about`}
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {t.navItems.about}
        </a>
      </li>
      <li>
        <a
          href={`/${lang}#experience`}
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {t.navItems.experience}
        </a>
      </li>
      <li>
        <a
          href={`/${lang}#projects`}
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {t.navItems.projects}
        </a>
      </li>
      <li>
        <a
          href={`/${lang}#education`}
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {t.navItems.education}
        </a>
      </li>
      <li class="ml-4 pl-4 border-l border-gray-300">
        <a
          href={`/${otherLang}/`}
          class="px-3 py-1 rounded border border-gray-700 text-gray-700 hover:bg-gray-100 transition-colors font-medium text-sm"
        >
          {otherLang.toUpperCase()}
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    if (window.scrollY > 100) {
      header?.classList.add("bg-white/80", "backdrop-blur-sm");
    } else {
      header?.classList.remove("bg-white/80", "backdrop-blur-sm");
    }
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
